{
  "name": "oneone-scripts",
  "author": "Serkan Aksoy",
  "contributors": [
    "Serkan Aksoy serkanaksy@proton.me"
  ],
  "description": "Automation scripts and modpack management for the OneOne hardcore Skyblock experience.",
  "license": "MIT",
  "module": "automation/build.ts",
  "type": "module",
  "scripts": {
    "start": "bun run build",
    "build": "bun run automation/build.ts",
    "rebuild": "rm -rf instance && bun run build",
    "add": "bun run automation/add.ts",
    "link-prism": "bun run automation/link-prism.ts",
    "lint": "eslint \"{automation,kubejs}/**/*.ts\" --cache",
    "lint:fix": "eslint \"{automation,kubejs}/**/*.ts\" --fix",
    "format": "prettier --write \"{automation,kubejs}/**/*.ts\"",
    "format:check": "prettier --check \"{automation,kubejs}/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {},
  "dependencies": {
    "consola": "^3.4.2",
    "ora": "^9.3.0",
    "prismarine-nbt": "^2.8.0",
    "yoctocolors": "^2.1.2"
  }
}
